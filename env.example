# Site URL. Local dev: http://localhost:3000. Production (Vercel): https://hirepen.net
NEXT_PUBLIC_SITE_URL=https://hirepen.net

# Public support email — shown in footer, Privacy, Terms (required for Creem live review)
NEXT_PUBLIC_SUPPORT_EMAIL=wukaiwei@hirepen.net

# AI provider (OpenAI-compatible) — server only, never use NEXT_PUBLIC_
# RECOMMENDED for 出海/美区: Alibaba Bailian (Qwen) US (Virginia) region.
# Get a US-region API key (region keys are NOT interchangeable across regions).
AI_API_KEY=
AI_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
AI_MODEL=qwen-flash-us
# Pro / Lifetime use this model when set (recommended: qwen-plus-us for better US job copy)
AI_MODEL_PAID=qwen-plus-us
# AI_PROVIDER=qwen
#
# Qwen US model options: qwen-flash-us (cheapest/fastest) | qwen-plus-us (higher quality)
#
# Switch provider by changing only these 3 vars:
#   OpenAI:     AI_BASE_URL=https://api.openai.com/v1            AI_MODEL=gpt-4o-mini
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1         AI_MODEL=openai/gpt-4o-mini
#   Groq:       AI_BASE_URL=https://api.groq.com/openai/v1       AI_MODEL=llama-3.3-70b-versatile
#
# Legacy DeepSeek fallback (used only if AI_API_KEY is empty):
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Auth session secret — REQUIRED for login (signs the session JWT + captcha cookies).
# Generate one with: openssl rand -base64 32
AUTH_SESSION_SECRET=

# Supabase — stores app_users (self-managed account/password), enables GitHub OAuth,
# and persists rate limits. Without these, login is disabled and limits use memory (dev only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AdSense — omit any value to disable ads completely
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=

# Analytics — omit to disable (scripts load only when set; see docs/SEO.md)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id

# Creem — omit CREEM_API_KEY to disable checkout buttons
# API base: auto from key prefix, or set explicitly:
#   Test:  CREEM_API_BASE_URL=https://test-api.creem.io  (creem_test_* keys)
#   Live:  CREEM_API_BASE_URL=https://api.creem.io       (creem_* keys)
# CREEM_API_BASE_URL=
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
NEXT_PUBLIC_CREEM_PRODUCT_PRO=
NEXT_PUBLIC_CREEM_PRODUCT_LIFETIME=

# SMTP (163) — enables "Forgot password?" on /login. Run supabase/migrations/002_password_reset.sql
# 163: enable SMTP in mailbox settings → generate 授权码 (not your login password)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# Name only is OK (auto-appends SMTP_USER email). Full form also works:
SMTP_FROM=HirePen
# SMTP_FROM=HirePen <you@163.com>

# Limits
FREE_DAILY_LIMIT=3
PRO_MONTHLY_LIMIT=50
